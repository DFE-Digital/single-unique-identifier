@startuml transfer-view-architecture-v2
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

Person(SafeguardingPractioners, "Safeguarding Practioners", "Directly working with children and families to provide social care. e.g. social worker")

System_Boundary(LA, "Local Authority Single-View System", $descr="Multiple instances, one per LA") {
    ContainerDb(ConsolidatedDataStore, "Consolidated Data Store", "SQL / NoSQL?", "Stores the consolidated records of any searched for child")

    Container(SingleViewWebPortal, "Single View Web Portal", "ASP.NET MVC, HTML", "Provides a single view of consolidated records about a searched for child")

    Container(TransferService, "Transfer & Aggregation Service", ".NET", "Uses the Find Service to discover which Custodians hold data about a specific NHS Number; then requests the data from the relevant Custodians; then aggregates any necessary data; and then updates the Consolidated Data Store")
}

System_Ext(SUI_Matcher, "SUI Matcher", $descr="Service to find NHS Number given specified details of a child")

System_Ext(Find_Service, "Find Service", $descr="Registry to manage and provide details about which Custodians hold information for a specified NHS Number")

' External Systems
Boundary(Custodians, "Custodian Systems") {
    System_Ext(LA_CMS, "LA CMS")
    System_Ext(SocialCare, "Social care")
    System_Ext(Education, "Education")
    System_Ext(Health, "Health")
    System_Ext(Crime, "Crime")
    System_Ext(Housing, "Housing")
}

' Relationships
Rel(SafeguardingPractioners, SingleViewWebPortal, "Uses")

Rel(SingleViewWebPortal, TransferService, "Requests", "HTTP")

Rel(SingleViewWebPortal, SUI_Matcher, "Requests", "HTTP")

Rel(TransferService, ConsolidatedDataStore, "Reads\n & Updates")

Rel(TransferService, Find_Service, "(1) Requests & Polls", "HTTP, HATEOAS")

Rel(TransferService, LA_CMS, "(2*) Requests", "HTTP, OpenAPI", "/events endpoint")
Rel(TransferService, Housing, "(2*) Requests", "HTTP, OpenAPI", "/events endpoint")
Rel(TransferService, SocialCare, "(2*) Requests", "HTTP, OpenAPI", "/events endpoint")
Rel(TransferService, Education, "(2*) Requests", "HTTP, OpenAPI", "/events endpoint")
Rel(TransferService, Health, "(2*) Requests", "HTTP, OpenAPI", "/events endpoint")
Rel(TransferService, Crime, "(2*) Requests", "HTTP, OpenAPI", "/events endpoint")

' Layout hints
Lay_L(SingleViewWebPortal, SUI_Matcher)

Lay_L(TransferService, Find_Service)

@enduml

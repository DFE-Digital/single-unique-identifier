{
   "tasks": [
      {
         "name": "Run gitleaks",
         "command": "dotnet",
         "args": [
            "pwsh",
            "-NoProfile",
            "-File",
            "./scripts/security/run-gitleaks.ps1"
         ]
      },
      {
         "name": "Run csharpier",
         "command": "dotnet",
         "args": [
            "csharpier",
            "format",
            "${staged}"
         ],
         "include": [
            "**/*.cs",
            "**/*.csx",
            "**/*.csproj",
            "**/*.props",
            "**/*.targets",
            "**/*.xml",
            "**/*.config"
         ]
      }
   ]
}

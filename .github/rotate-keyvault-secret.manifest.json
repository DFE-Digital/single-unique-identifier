{
  "profiles": {
    "find": {
      "terraform": {
        "root": "terraform/find",
        "state_key": "{environment}/find.tfstate"
      },
      "resources": {
        "resource_group_name": "{subscription_prefix}{environment_id}rg-{region_short}-{descriptor}",
        "key_vault_name": "{subscription_prefix}{environment_id}kv-{region_short}-findkv01",
        "function_app_name": "{subscription_prefix}{environment_id}func-{region_short}-find01",
        "base_url": "https://{function_app_name}.azurewebsites.net/api/"
      },
      "refresh_strategy": "function_app_key_vault_reference",
      "restart_strategy": "function_app",
      "verification": {
        "runner": "dotnet_test",
        "project": "Apps/Find/tests/SUI.Find.E2ETests/SUI.Find.E2ETests.csproj",
        "filter": "Suite=Smoke",
        "secret_env_name": "E2E__FindApiKey",
        "previous_secret_env_name": "E2E__PreviousFindApiKey"
      }
    }
  },
  "secrets": {
    "find-match-api-key": {
      "display_name": "Find Match API key",
      "profile": "find",
      "terraform": {
        "rotate_targets": [
          "random_password.find_match_api_key",
          "time_static.find_match_api_key_expiry_base",
          "azurerm_key_vault_secret.find_match_api_key"
        ],
        "replace_targets": [
          "random_password.find_match_api_key",
          "time_static.find_match_api_key_expiry_base"
        ]
      },
      "schedule": {
        "enabled": true,
        "environments": [
          "d01",
          "d02"
        ]
      }
    }
  }
}

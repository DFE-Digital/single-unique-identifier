  "components": {
    "schemas": {
      "AddressV1": {
        "type": "object",
        "properties": {
          "line1": {
            "type": "string",
            "additionalProperties": false,
            "description": "Line 1 of the address",
            "nullable": true,
            "example": "123 Kew Gardens"
          },
          "line2": {
            "type": "string",
            "additionalProperties": false,
            "description": "Line 2 of the address",
            "nullable": true,
            "example": "Bakers Lane"
          },
          "townOrCity": {
            "type": "string",
            "additionalProperties": false,
            "description": "Town or city",
            "nullable": true,
            "example": "Bath"
          },
          "county": {
            "type": "string",
            "additionalProperties": false,
            "description": "County",
            "nullable": true,
            "example": "Somerset"
          },
          "postcode": {
            "type": "string",
            "additionalProperties": false,
            "description": "Postcode",
            "nullable": true,
            "example": "BA1 2AB"
          }
        },
        "additionalProperties": false,
        "nullable": true
      },
      "ChildrensServicesDetailsRecordV1": {
        "type": "object",
        "properties": {
          "keyWorker": {
            "type": "string",
            "additionalProperties": false,
            "description": "CS - Key worker",
            "nullable": true,
            "example": "Alex Patel"
          },
          "dutyContactDetails": {
            "type": "array",
            "items": {
              "type": "string",
              "additionalProperties": false
            },
            "additionalProperties": false,
            "description": "CS - Duty contact details",
            "nullable": true,
            "example": "csc@bromley.gov.uk, 08792675387"
          },
          "teamInvolvement": {
            "type": "array",
            "items": {
              "type": "string",
              "additionalProperties": false
            },
            "additionalProperties": false,
            "description": "CS - Team involvement",
            "nullable": true,
            "example": "Disabled Childrens Team, Neighbourhood Team"
          },
          "childrensServicesReferrals": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChildrensServicesReferralV1"
            },
            "additionalProperties": false,
            "description": "CS - Referrals",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Details related to the Children's Services for a specific child."
      },
      "ChildrensServicesReferralV1": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "additionalProperties": false,
            "description": "CS - Referral history - Date",
            "format": "date",
            "nullable": true,
            "example": "2025-08-16"
          },
          "type": {
            "type": "string",
            "additionalProperties": false,
            "description": "CS - Referral history - Type",
            "nullable": true,
            "example": "Early Help"
          }
        },
        "additionalProperties": false
      },
      "CrimeDataRecordV1": {
        "type": "object",
        "properties": {
          "policeMarkerDetails": {
            "type": "string",
            "additionalProperties": false,
            "description": "Police marker details",
            "nullable": true,
            "example": "Individuals at the address may resort to violent behaviour"
          },
          "servicesKnownTo": {
            "type": "array",
            "items": {
              "type": "string",
              "additionalProperties": false
            },
            "additionalProperties": false,
            "description": "Crime - Services known to",
            "nullable": true,
            "example": "Youth justice service (YJS), Police"
          },
          "lastPoliceProtectionPowerEvent": {
            "type": "string",
            "additionalProperties": false,
            "description": "Last Police Protection Power event",
            "nullable": true
          },
          "missingEpisodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CrimeMissingEpisodeV1"
            },
            "additionalProperties": false,
            "description": "Police - Missing Episodes",
            "nullable": true
          },
          "linkedCrimeRisks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LinkedCrimeRiskV1"
            },
            "additionalProperties": false,
            "description": "Linked crime risks",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Crime-linked data about a specific child."
      },

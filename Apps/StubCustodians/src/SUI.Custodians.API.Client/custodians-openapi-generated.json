          "educationSettingAddress": {
            "$ref": "#/components/schemas/AddressV1"
          },
          "educationSettingTelephone": {
            "type": "string",
            "additionalProperties": false,
            "description": "Education setting - Telephone",
            "nullable": true,
            "example": "0123456789"
          },
          "yearlyEducationAttendances": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/YearlyEducationAttendanceV1"
            },
            "additionalProperties": false,
            "description": "Yearly Education Attendances",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Education related data about a specific child."
      },

        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "additionalProperties": false,
            "description": "Missing episode date",
            "format": "date",
            "nullable": true,
            "example": "2025-06-12"
          },
          "returnedHomeInterviewAttended": {
            "type": "boolean",
            "additionalProperties": false,
            "description": "Missing episode returned home interview attended",
            "nullable": true,
            "example": "true"
          }
        },
        "additionalProperties": false
      },

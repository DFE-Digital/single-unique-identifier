<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="LocalNuGetFeed" value="C:\Dev-DfE\local-test-nuget-feed" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="LocalNuGetFeed">
      <package pattern="SUI.*" />
    </packageSource>
  </packageSourceMapping>
  <packageSourceCredentials>
    <DFEDigital>
      <add key="Username" value="%GITHUB_USERNAME%" />
      <add key="ClearTextPassword" value="%GITHUB_TOKEN_DFENUGET%" />
    </DFEDigital>
  </packageSourceCredentials>
</configuration>

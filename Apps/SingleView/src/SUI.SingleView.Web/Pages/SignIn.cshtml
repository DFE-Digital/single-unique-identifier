@page
@model SUI.SingleView.Web.Pages.SignIn

@{
    ViewBag.Title = "Access the child safeguarding service";
    ViewBag.BackLinkPath = nameof(OnboardingStep1);
}

<form method="post">
    <govuk-fieldset>
        <govuk-fieldset-legend is-page-heading="true" class="govuk-fieldset__legend--l">
            @ViewBag.Title
        </govuk-fieldset-legend>
        <p class="govuk-body">Enter your details below to access your safeguarding service account</p>
        <govuk-input name="Username" for="Username" input-class="govuk-input--width-10" input-autocapitalize="false"
                     input-autocomplete="username" spellcheck="false">
            <govuk-input-label>Username</govuk-input-label>
            <govuk-input-error-message/>
        </govuk-input>
        <govuk-password-input name="Password" for="Password" input-class="govuk-input--width-10">
            <govuk-password-input-label>Password</govuk-password-input-label>
            <govuk-password-input-error-message/>
        </govuk-password-input>
        <govuk-button is-start-button="true" type="submit">Sign In</govuk-button>
    </govuk-fieldset>
</form>
@using System.Diagnostics
@using SUI.UIHarness.Web.Models
@using SUI.UIHarness.Web.Models.Find
@using SUI.UIHarness.Web.Services

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h2 class="h5 mb-2">Selected person</h2>
        @if (CurrentPerson == null)
        {
            <div class="text-muted">No person selected yet.</div>
        }
        else
        {
            <div class="" id="selectedPersonText">@CurrentPerson.Given @CurrentPerson.Family - NHS @CurrentPerson.NhsNumber</div>
        }
    </div>
</div>

@if (_showFindProgress)
{
    <div id="findRecordsProgressWrap" class="mb-3">
        <div class="d-flex justify-content-start align-items-center mb-1">
            <div class="spinner-border spinner-border-sm text-primary me-1" role="status"></div>
            <span class="text-muted">Searching custodians...</span>
            <span id="findRecordsProgressText" class="text-muted"></span>
        </div>
        <div class="progress" role="progressbar" aria-label="Find records progress">
            <div id="findRecordsProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" style="width:@(_findProgressPercentage)%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
    </div>
}

<div class="table-responsive">
    <table class="table table-striped align-middle" id="findRecordsTable">
        <thead>
            <tr>
                <th>Custodian</th>
                <th>Record type</th>
                <th>Record ID</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @if (_foundRecordsFor?.Org == SelectedOrg && _foundRecordsFor?.NhsNumber == CurrentPerson?.NhsNumber)
            {
                foreach (var p in _foundRecords)
                {
                    <tr data-record-id="@p.Id">
                        <td>@p.CustodianName</td>
                        <td>@p.Type</td>
                        <td>@p.Id</td>
                        <td>@p.Url</td>
                        <td>
                            <button class="btn btn-primary" type="button" @onclick="_ => SetCurrentRecord(p)">Fetch Record</button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="mt-4">
    <h2 class="h5">What this demo is showing</h2>

    <p class="mb-2">
        The Find a record service is designed to find out which organisations across the UK have information about a child.
        This tab simulates that discovery step by sending a search request out to a set of custodians.
    </p>

    <p class="mb-2">
        We can either fan out requests directly to custodians, or create search tasks that custodians carry out via polling.
        Either way, custodians are expected to respond to a search request by confirming whether they know about a child and what type of record they hold.
    </p>

    <p class="mb-0">
        The results are collated into a manifest. Each manifest entry includes a unique URL that can be used to retrieve more detailed information about the record held by that custodian.
        That retrieval step is what the next tab will simulate.
    </p>
</div>

@code {
    [Parameter]
    public LocalPerson? CurrentPerson { get; set; }
    
    [Parameter]
    public required string SelectedOrg { get; set; }
    
    [Parameter]
    public required string Architecture { get; set; }
    
    [Parameter]
    public EventCallback<LocalRecord> CurrentRecordChanged { get; set; }
    
    [Parameter]
    public EventCallback<string> CurrentWorkItemIdChanged { get; set; }

    private bool _showFindProgress;
    private int _findProgressPercentage;
    private readonly List<LocalRecord> _foundRecords = [];
    private (string? Org, string? NhsNumber)? _foundRecordsFor;
    
    [Inject]
    public required IFindService FindService { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (!_showFindProgress && _foundRecordsFor != (SelectedOrg, CurrentPerson?.NhsNumber))
        {
            await FindRecords();
        }
    }

    private async Task FindRecords()
    {
        if (CurrentPerson?.NhsNumber == null)
        {
            return;
        }
        
        _foundRecords.Clear();
        _foundRecordsFor = null;
        _findProgressPercentage = 0;
        _showFindProgress = true;
        var currentNhsNumber = CurrentPerson.NhsNumber;
        var usePolling = Architecture == "Polling";

        var sleepInterval = TimeSpan.FromMilliseconds(250);
        var maxTimeToWaitForFanout = TimeSpan.FromSeconds(90);

        try
        {
            var workItemId = await FindService.StartSearch(SelectedOrg, CurrentPerson.NhsNumber, usePolling);
            await CurrentWorkItemIdChanged.InvokeAsync(workItemId);

            var keepPolling = true;
            var stopwatch = Stopwatch.StartNew();
            while (keepPolling && !HasCurrentNhsNumberChanged())
            {
                var result = await FindService.FindRecords(SelectedOrg, workItemId, usePolling);

                if (HasCurrentNhsNumberChanged())
                {
                    break;
                }

                if (usePolling)
                {
                    _findProgressPercentage = result.CompletenessPercentage;
                }
                else
                {
                    _findProgressPercentage = (int)Math.Round(stopwatch.Elapsed / maxTimeToWaitForFanout * 100);
                }

                await InvokeAsync(StateHasChanged);

                foreach (var resultItem in result.Items)
                {
                    var record = new LocalRecord(resultItem.RecordId ?? resultItem.RecordUrl, resultItem.RecordUrl, resultItem.RecordType, resultItem.CustodianName ?? string.Empty);
                
                    if (_foundRecords.Contains(record))
                    {
                        continue;
                    }

                    _foundRecords.Add(record);
                    _foundRecordsFor ??= (SelectedOrg, CurrentPerson.NhsNumber);
                
                    await InvokeAsync(StateHasChanged);
                }
            
                if (_findProgressPercentage >= 100 || result.Status == FindSearchStatus.Completed)
                {
                    keepPolling = false;
                }
                else
                {
                    await Task.Delay(sleepInterval);
                }
            }
        }
        finally
        {
            _showFindProgress = false;
            await InvokeAsync(StateHasChanged);
        }
        
        return;

        bool HasCurrentNhsNumberChanged() => currentNhsNumber != CurrentPerson?.NhsNumber;
    }

    private async Task SetCurrentRecord(LocalRecord localRecord)
    {
        await CurrentRecordChanged.InvokeAsync(localRecord);
    }
}
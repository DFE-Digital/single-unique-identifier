@{
    ViewData["Title"] = "Sign in";
}

<div class="container" style="max-width: 720px; padding-top: 24px;">
    <h1 class="mb-4">Sign in</h1>

    <form method="post" action="/account/login">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label for="org" class="form-label">Organisation</label>
            <select id="org" name="org" class="form-select">
                <option value="">Select…</option>
                <option value="LOCAL-AUTHORITY-01">LOCAL-AUTHORITY-01</option>
                <option value="EDUCATION-01">EDUCATION-01</option>
                <option value="HEALTH-01">HEALTH-01</option>
            </select>
            <div class="text-danger">@Html.ValidationMessage("org")</div>
        </div>

        <button type="submit" class="btn btn-primary">Sign in</button>
    </form>
</div>

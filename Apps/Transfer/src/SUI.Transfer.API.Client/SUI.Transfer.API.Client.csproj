<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <Version>0.0.8</Version>
    <Title>SUI.Transfer.API.Client</Title>
    <Authors>Department for Education</Authors>
    <RepositoryUrl>https://github.com/DFE-Digital/single-unique-identifier/</RepositoryUrl>
    <Description>This client is used for connecting to the SUI Transfer Service and is generated from the Open API Spec.</Description>
    <PackageProjectUrl>https://github.com/DFE-Digital/single-unique-identifier/</PackageProjectUrl>
    <PackageReadmeFile>readme.md</PackageReadmeFile>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference
      Include="Microsoft.Extensions.DependencyInjection.Abstractions"
      Version="10.0.2"
    />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.2" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="obj\" />
    <None Include="readme.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>

{
  "openapi": "3.0.1",
  "info": {
    "title": "SUI.Transfer.API | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/transfer": {
      "post": {
        "tags": [
          "SUI Transfer API - Transfer"
        ],
        "summary": "Transfer custodian data for a given child",
        "description": "This endpoint begins a job that requests external custodian systems for their data on a specific child, aggregates the data where necessary, and returns the data in a consolidated form.",
        "requestBody": {
          "description": "The single unique identifier for the data which is being requested.",
          "content": {
            "application/json": {
              "schema": {
                "type": "string"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueuedTransferJobState"
                }
              }
            }
          }
        },
        "security": [
          {
            "x-api-key": [ ]
          }
        ]
      }
    },
    "/api/v1/transfer/{jobId}": {
      "delete": {
        "tags": [
          "SUI Transfer API - Transfer"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "description": "The guid id of the job being cancelled.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CancelledTransferJobState"
                }
              }
            }
          }
        },
        "security": [
          {
            "x-api-key": [ ]
          }
        ]
      },
      "get": {
        "tags": [
          "SUI Transfer API - Transfer"
        ],
        "summary": "Get Status of Transfer job",
        "description": "This endpoint returns the status of a given transfer job.",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "description": "The guid id of the job whose status is being requested.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransferJobState"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        },
        "security": [
          {
            "x-api-key": [ ]
          }
        ]
      }
    },
    "/api/v1/transfer/{jobId}/results": {
      "get": {
        "tags": [
          "SUI Transfer API - Transfer"
        ],
        "summary": "Get Result of Transfer Job",
        "description": "This endpoint returns the results of a transfer job, if completed.",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "description": "The guid id of the job whose results are being requested.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompletedTransferJobState"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransferJobState"
                }
              }
            }
          },
          "404": {
            "description": "Not Found"
          }
        },
        "security": [
          {
            "x-api-key": [ ]
          }
        ]
      }
    }
  },

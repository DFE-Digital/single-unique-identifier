{
    "version": "2.0",
    "telemetryMode": "OpenTelemetry",
    "extensions": {
      "http": {
        "routePrefix": ""
      }
    },
    "logging": {
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Request"
            },
            "enableLiveMetricsFilters": true
        }
    }
}